# OpenSSL PIV Authentication certificate configuration
#
# Mimics a US Government PIV auth cert (FIPS 201 / SP 800-73)
# so the pcaps contain realistic client identity information.

[ req ]
default_bits       = 2048
default_md         = sha256
distinguished_name = req_dn
prompt             = no

[ req_dn ]
C  = US
O  = U.S. Government
OU = Department of Test
CN = DOE.JOHN.1234567890

[ v3_piv_auth ]
basicConstraints       = CA:FALSE
keyUsage               = critical, digitalSignature
extendedKeyUsage       = clientAuth
subjectKeyIdentifier   = hash
authorityKeyIdentifier = keyid, issuer

# FPKI certificate policy: id-fpki-common-authentication
certificatePolicies    = @piv_policies

# Subject Alternative Name — UUID (FASC-N mapping) + email
subjectAltName         = URI:urn:uuid:f81d4fae-7dec-11d0-a765-00a0c91e6bf6, email:john.doe@test.gov

# Authority Information Access — OCSP responder + CA Issuers
authorityInfoAccess    = OCSP;URI:http://ocsp.test.gov/piv, caIssuers;URI:http://pki.test.gov/certs/PIVAuthCA.cer

# CRL Distribution Points
crlDistributionPoints  = URI:http://pki.test.gov/crl/PIVAuthCA.crl

[ piv_policies ]
policyIdentifier = 2.16.840.1.101.3.2.1.3.13
